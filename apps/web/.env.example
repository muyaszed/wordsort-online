# ─── API ─────────────────────────────────────────────────────────────────────
# Server-side only — used by Next.js Server Components (daily puzzle fetch)
API_URL=http://localhost:3001

# Client-side — used by browser fetches (auth, leaderboard)
# IMPORTANT: must include the /api prefix
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# ─── Sentry (optional) ───────────────────────────────────────────────────────
# Leave blank to disable error tracking in development
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
