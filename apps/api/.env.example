# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Neon or local)
DATABASE_URL=postgresql://user:password@ep-xxx-yyy.us-east-1.aws.neon.tech/wordsort?sslmode=require

# ─── Auth ────────────────────────────────────────────────────────────────────
# Secret used to sign JWT access tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=replace-me-with-a-random-32-byte-base64-string

# Google OAuth (leave blank to disable Google login — routes return 501)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match the redirect URI registered in your Google Cloud Console OAuth app
GOOGLE_REDIRECT_URI=https://your-domain.vercel.app/auth/callback

# ─── Server ──────────────────────────────────────────────────────────────────
# Port for the API server (default: 3001)
PORT=3001

# Origin of the web app for CORS (default: http://localhost:3000)
WEB_ORIGIN=http://localhost:3000
