# PostgreSQL connection string (Neon or local)
DATABASE_URL=postgresql://user:password@ep-xxx-yyy.us-east-1.aws.neon.tech/wordsort?sslmode=require

# Port for the API server (default: 3001)
PORT=3001

# Origin of the web app for CORS (default: http://localhost:3000)
WEB_ORIGIN=http://localhost:3000
