# ─── Database ────────────────────────────────────────────────────────────────
# Neon serverless Postgres — get from https://console.neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx-yyy.us-east-1.aws.neon.tech/wordsort?sslmode=require

# ─── Redis (optional) ────────────────────────────────────────────────────────
# Upstash Redis — get from https://console.upstash.com
# If unset, caching is skipped and the API still works.
REDIS_URL=rediss://default:token@xxx.upstash.io:6380

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=change-me-in-production

# Google OAuth (leave blank to disable Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match the redirect URI registered in Google Cloud Console
GOOGLE_REDIRECT_URI=https://your-domain.vercel.app/auth/callback

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# Origin of the web app for CORS (no trailing slash)
WEB_ORIGIN=https://your-domain.vercel.app
